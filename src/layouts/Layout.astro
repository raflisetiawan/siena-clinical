---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Siena Clinical', description = 'Siena Clinical - Research Organization' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Prompt:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet" />
		<title>{title}</title>
	</head>
	<body class="font-sans text-siena-primary bg-white relative min-h-screen flex flex-col">
		<!-- Global Supergraphic Watermark -->
		<div 
			class="fixed inset-0 z-[-1] opacity-[0.03] pointer-events-none mix-blend-multiply"
			style="background-image: url('/src/assets/Supergraphic Siena Clinical (Blue).webp'); background-size: cover; background-position: center; background-repeat: no-repeat;"
		></div>
		
		<div class="relative z-0 flex flex-col flex-1">
			<Header />
			<main class="flex-1">
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
