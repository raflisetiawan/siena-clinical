---
import { Image } from 'astro:assets';
import shieldIcon from '../assets/siena-icon/Dark Blue/Shield (Blue).png';
import globalStandardIcon from '../assets/siena-icon/Dark Blue/Global Standard (Blue).png';
import efficienceIcon from '../assets/siena-icon/Dark Blue/Efficience.png';

// Core Values Component
const values = [
  {
    title: 'Integrity',
    description: 'Preserving the highest scientific quality of our deliverables.',
    iconSrc: shieldIcon,
    iconAlt: 'Integrity Icon'
  },
  {
    title: 'Consistency',
    description: 'Delivering standardized-excellence across all engagements',
    iconSrc: globalStandardIcon,
    iconAlt: 'Consistency Icon'
  },
  {
    title: 'Efficiency',
    description: 'Maximizing value delivered without sacrificing scientific accuracy',
    iconSrc: efficienceIcon,
    iconAlt: 'Efficiency Icon'
  }
];
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-heading text-3xl font-semibold text-siena-primary mb-16 text-center">
      Three core values that define how Siena Clinical operates
    </h2>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
      {values.map((value) => (
        <div class="flex flex-col items-center">
          <!-- Icon Image -->
          <div class="mb-6 h-20 flex justify-center items-center">
            <Image src={value.iconSrc} alt={value.iconAlt} class="max-h-full w-auto object-contain" />
          </div>
          
          <h3 class="font-heading text-xl font-bold text-siena-primary mb-3">
            {value.title}
          </h3>
          
          <p class="text-gray-600 leading-relaxed text-sm md:text-base max-w-xs mx-auto">
            {value.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
