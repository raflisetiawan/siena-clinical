---
// Integrated Capabilities Component
const capabilities = [
  {
    title: 'Research',
    description: 'We are your full partner for everything from strategy to execution.',
    // Magnifying glass icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-20 h-20 mx-auto text-siena-primary">
            <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" />
           </svg>`,
    readMoreUrl: ''
  },
  {
    title: 'Consultation',
    description: 'We are more than happy to be your thinking partner for your project',
    // Chat bubble / presentation icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-20 h-20 mx-auto text-siena-primary">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 0 1 .865-.501 48.172 48.172 0 0 0 3.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0 0 12 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018Z" />
           </svg>`,
    readMoreUrl: ''
  },
  {
    title: 'Upskilling',
    description: 'We provide tailored-needs training, workshops and short-courses',
    // Bar chart with arrow icon
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-20 h-20 mx-auto text-siena-primary">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941" />
           </svg>`,
    readMoreUrl: '/capability'
  }
];
---

<section class="py-24 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center max-w-4xl mx-auto mb-16">
      <h2 class="font-heading text-3xl font-semibold text-siena-primary mb-6">
        One organization. Three integrated capabilities.
      </h2>
      <p class="text-gray-600 leading-relaxed text-base">
        Siena Clinical is a Research Ecosystem Partner from Indonesia that integrates clinical research, strategic consultation, and professional upskilling within a single hybrid structure. We bridge Academia and Industry with scientific standards that can be fully accounted for.
      </p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 text-center">
      {capabilities.map((item) => (
        <div class="flex flex-col items-center">
          <!-- Icon injected as raw HTML -->
          <div class="mb-6" set:html={item.icon} />
          
          <h3 class="font-heading text-xl font-bold text-siena-primary mb-3">
            {item.title}
          </h3>
          
          <p class="text-gray-600 leading-relaxed text-sm md:text-base max-w-xs mx-auto">
            {item.description}
          </p>

          {item.readMoreUrl && (
            <a href={item.readMoreUrl} class="mt-4 text-yellow-500 font-medium hover:text-yellow-600 transition-colors inline-flex items-center gap-1">
              Read more <span aria-hidden="true">&rarr;</span>
            </a>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
